# Copy to `.env.local` (gitignored). Used only by `app/api/chat/route.ts` (server-side).

# Modal `LobotomyInference.generate` URL from: `modal deploy ./backend/modal_app.py`
# Example: https://<workspace>--lobotomy-backend-lobotomyinference-generate.modal.run
MODAL_URL=

# Optional alias (same value as MODAL_URL)
# MODAL_GENERATE_URL=

# Gemini API Key for response flagging
# Get from: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=

# Hackathon: shorter cafe system prompt so Dolphin is less "refusal/meta" — rely on Lobotomy steering for safety demo
# COWBOY_CAFE_HACKATHON_BASELINE=true

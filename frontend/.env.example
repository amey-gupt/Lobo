# Modal LobotomyAdmin — full URLs from `modal deploy` (FastAPI endpoints differ per method).
MODAL_ADMIN_URL_GET=https://your-workspace--lobotomy-backend-LobotomyAdmin-get-config.modal.run
MODAL_ADMIN_URL_SET=https://your-workspace--lobotomy-backend-LobotomyAdmin-set-config.modal.run

# Same value as Modal secret `admin-secret` ADMIN_TOKEN (server-only; never NEXT_PUBLIC_*).
MODAL_ADMIN_TOKEN=
# Or: ADMIN_TOKEN=

# LobotomyInference.generate — same as Cowboy Cafe (server-only). Required for admin chat panel.
MODAL_URL=https://your-workspace--lobotomy-backend-LobotomyInference-generate.modal.run
# Or: MODAL_GENERATE_URL=

# Optional: shorter system prompt + hackathon baseline (same env as cowboy_cafe).
# COWBOY_CAFE_HACKATHON_BASELINE=true

# UI maps each channel to multiplier 0…2× (see src/lib/steering-config.ts); backend may still cap combined step.

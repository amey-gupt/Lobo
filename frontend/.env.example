# Modal LobotomyAdmin — full URLs from `modal deploy` (FastAPI endpoints differ per method).
MODAL_ADMIN_URL_GET=https://your-workspace--lobotomy-backend-LobotomyAdmin-get-config.modal.run
MODAL_ADMIN_URL_SET=https://your-workspace--lobotomy-backend-LobotomyAdmin-set-config.modal.run

# Same value as Modal secret `admin-secret` ADMIN_TOKEN (server-only; never NEXT_PUBLIC_*).
MODAL_ADMIN_TOKEN=
# Or: ADMIN_TOKEN=

# Optional: if you add /api/chat proxy to LobotomyInference (GPU).
# MODAL_URL=https://...
